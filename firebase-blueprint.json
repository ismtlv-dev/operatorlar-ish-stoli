{
  "entities": {
    "Operator": {
      "title": "Operator",
      "description": "An operator managing school records",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Operator unique identifier"
        },
        "name": {
          "type": "string",
          "description": "Operator full name"
        },
        "records": {
          "type": "array",
          "description": "Pristine and updated school records in operator's portfolio"
        }
      },
      "required": ["id", "name", "records"]
    },
    "EditLog": {
      "title": "EditLog",
      "description": "Log entry of modifications",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique log entry ID"
        },
        "operatorId": {
          "type": "string",
          "description": "ID of operator who performed change"
        },
        "operatorName": {
          "type": "string",
          "description": "Name of operator"
        },
        "schoolName": {
          "type": "string",
          "description": "Name of school updated"
        },
        "field": {
          "type": "string",
          "description": "Modified field (e.g. Holat, Izoh)"
        },
        "oldValue": {
          "type": "string",
          "description": "Value before change"
        },
        "newValue": {
          "type": "string",
          "description": "Value after change"
        },
        "timestamp": {
          "type": "string",
          "description": "Date-time stamp of action"
        }
      },
      "required": ["id", "operatorId", "operatorName", "schoolName", "field", "oldValue", "newValue", "timestamp"]
    }
  },
  "firestore": {
    "/operators/{operatorId}": {
      "schema": "Operator",
      "description": "Collection of operators with their assigned school records"
    },
    "/activityLogs/{logId}": {
      "schema": "EditLog",
      "description": "Database-wide system action log and records"
    }
  }
}
